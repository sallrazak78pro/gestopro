# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/gestopro?retryWrites=true&w=majority

# NextAuth — générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=<secret-aleatoire-32-bytes-base64>
NEXTAUTH_URL=https://votre-domaine.vercel.app

# Cloudinary — https://cloudinary.com
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>
